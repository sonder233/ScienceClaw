# Exclude large/irrelevant directories from Docker build context
# (used when backend build context is the project root)
workspace/
.git/
.gitignore
RpaClaw/frontend/node_modules/
RpaClaw/frontend/.npm-cache/
RpaClaw/frontend/dist/
RpaClaw/websearch/
!RpaClaw/websearch/seekr_sdk.py
*.pyc
__pycache__/
.env
.cursor/
