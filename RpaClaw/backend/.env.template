# ── 基础服务 ──
MONGODB_HOST=localhost
MONGODB_PORT=27014
MONGODB_USER=
MONGODB_PASSWORD=
SANDBOX_REST_URL=http://localhost:18080
SANDBOX_MCP_URL=http://localhost:18080/mcp
SANDBOX_PUBLIC_URL=http://localhost:18080
WEBSEARCH_BASE_URL=http://localhost:8068
STORAGE_BACKEND=local

# ── 统一根目录 ──
# 设置 RPA_CLAW_HOME 后，以下子目录自动派生：
#   workspace        → RPA_CLAW_HOME/workspace
#   external_skills  → RPA_CLAW_HOME/external_skills
#   builtin_skills   → RPA_CLAW_HOME/builtin_skills
#   data             → RPA_CLAW_HOME/data
# 也可单独设置覆盖：WORKSPACE_DIR / EXTERNAL_SKILLS_DIR / BUILTIN_SKILLS_DIR / LOCAL_DATA_DIR
RPA_CLAW_HOME=

# Docker 沙箱内的根目录（默认 /home/rpaclaw，一般无需修改）
# SANDBOX_RPA_CLAW_HOME=/home/rpaclaw
